# ─────────────────────────────────────────────────────────────────────────────
# LaunchDarkly Demo App — environment configuration
# Copy this file to `.env` and fill in real values, or leave blank to run in
# offline/mock mode (the app falls back to a local TestData-style flag source).
# ─────────────────────────────────────────────────────────────────────────────

# CLIENT-SIDE ID — safe to expose in a browser bundle. Find it under
# Account settings → Projects → <your project> → <environment> → Client-side ID.
# CRA only exposes vars prefixed with REACT_APP_ to the browser.
REACT_APP_LD_CLIENT_ID=

# Optional: force offline/mock mode even if a client ID is present.
# REACT_APP_LD_OFFLINE=true

# ─────────────────────────────────────────────────────────────────────────────
# SERVER-SIDE credentials — used ONLY by the Node scripts in /scripts, never by
# the browser bundle. Keep these secret; they are NOT prefixed with REACT_APP_.
# ─────────────────────────────────────────────────────────────────────────────

# SDK key for the server-side / AI SDK examples (scripts/server, scripts/ai).
LD_SDK_KEY=

# REST API access token (Account settings → Authorization). Grant it the
# permissions the scripts need (writer or a custom role). Used by scripts/api.
LD_API_TOKEN=

# Project & environment keys the scripts operate against.
LD_PROJECT_KEY=default
LD_ENVIRONMENT_KEY=production

# API base URL. Override for EU (https://app.eu.launchdarkly.com) or
# Federal (https://app.launchdarkly.us) instances.
LD_API_BASE_URL=https://app.launchdarkly.com
